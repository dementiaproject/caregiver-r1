# Patch to apply inside your verl-GDPO fork.
#
# Apply with:
#     cd /path/to/verl-GDPO
#     git apply /path/to/caregiver-r1/docs/verl_patch.diff
#
# This adds the `ec_mtrl_dual_horizon` advantage estimator branch and
# registers our custom rollout + reward manager in verl's worker registry.

diff --git a/verl/trainer/ppo/ray_trainer.py b/verl/trainer/ppo/ray_trainer.py
--- a/verl/trainer/ppo/ray_trainer.py
+++ b/verl/trainer/ppo/ray_trainer.py
@@ -195,6 +195,12 @@ def compute_advantage(data, adv_estimator, gamma, lam, num_repeat=1):
         data.batch['advantages'] = advantages
         data.batch['returns'] = advantages

+    elif adv_estimator == 'ec_mtrl_dual_horizon':
+        # caregiver-r1 EC-MTRL: α-fused trajectory + turn advantage with
+        # binary hard-veto safety gate. See docs/verl_integration.md.
+        from caregiver_r1.training.verl_advantage_patch import compute_advantage_ec_mtrl
+        data = compute_advantage_ec_mtrl(data, cfg=...)  # FILL: thread `self.config.algorithm` here
+
     else:
         raise NotImplementedError
     return data

